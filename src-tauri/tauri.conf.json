{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/refs/heads/main/.schema/tauri.schema.json",
  "productName": "Nitrite",
  "version": "6.1.0",
  "identifier": "com.nitrite.tool",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5175",
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "NiTriTe V26.0 — Maintenance Informatique Professionnelle",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "resizable": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' asset: blob: data:; connect-src 'self' http://localhost:11434 http://localhost:1420 tauri: ipc:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "displayLanguageSelector": false
      }
    }
  }
}


